{
	"name": "vite-radix-vanilla-extract",
	"version": "0.1.0",
	"type": "module",
	"description": "Radix UI dialog demo components styled with Vanilla Extract (ESM, publishable).",
	"license": "MIT",
	"files": [
		"dist",
		"README.md",
		"README.zh-TW.md"
	],
	"sideEffects": [
		"**/*.css"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./components/DialogDemo": {
			"types": "./dist/components/DialogDemo.d.ts",
			"import": "./dist/components/DialogDemo.js",
			"default": "./dist/components/DialogDemo.js"
		},
		"./components/DialogDemo.css": "./dist/components/DialogDemo.css"
	},
	"scripts": {
		"dev": "vite build --watch",
		"build": "vite build && tsc -p tsconfig.build.json"
	},
	"peerDependencies": {
		"@radix-ui/react-dialog": "^1.1.0",
		"react": "^18.0.0 || ^19.0.0",
		"react-dom": "^18.0.0 || ^19.0.0"
	},
	"devDependencies": {
		"@radix-ui/react-dialog": "^1.1.15",
		"@types/react": "^18.3.26",
		"@types/react-dom": "^18.3.7",
		"@vanilla-extract/css": "^1.17.4",
		"@vanilla-extract/recipes": "^0.5.7",
		"@vanilla-extract/vite-plugin": "^5.1.4",
		"@vitejs/plugin-react": "^4.3.4",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"typescript": "^5.9.3",
		"vite": "^5.4.10",
		"vite-plugin-lib-inject-css": "^2.2.2"
	}
}
